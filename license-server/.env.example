PORT=8787
DATABASE_URL=postgres://user:password@host:5432/license_db
# SSL DB: disable (rede interna), insecure (TLS sem validar CA), strict (TLS com validacao de CA)
PGSSL_MODE=disable
# Necessario somente em PGSSL_MODE=strict (conteudo PEM da CA)
# PGSSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
LICENSE_HMAC_SECRET=troque-por-segredo-forte
ADMIN_TOKEN=troque-por-token-admin-forte
ONLINE_VALID_MS=900000
GRACE_MS=86400000
